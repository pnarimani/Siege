.siege-button {
    border-radius: 4px;
    padding: 8px 16px;
    font-size: 14px;
    -unity-font-style: bold;
}

.gameplay-header {
    flex-grow: 1;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 70px;
}

.gameplay-footer {
    flex-grow: 1;
    position: absolute;
    bottom: 0;
    height: 100px;
    left: 0;
    right: 0;
}
